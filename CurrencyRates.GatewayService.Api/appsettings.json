{
  "Jwt": {
    "Issuer": "CurrencyRates",
    "Audience": "CurrencyRates",
    "SecretKey": "CurrencyRates_Dev_SecretKey_ChangeMe_32+"
  },
  "ReverseProxy": {
    "Routes": {
      "finance-dev": {
        "ClusterId": "finance",
        "AuthorizationPolicy": "anonymous",
        "Match": {
          "Path": "/api/finance/dev/{**catch-all}"
        }
      },
      "finance": {
        "ClusterId": "finance",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/finance/{**catch-all}"
        }
      },
      "users-register": {
        "ClusterId": "users",
        "AuthorizationPolicy": "anonymous",
        "Match": {
          "Path": "/api/users/register",
          "Methods": [ "POST" ]
        }
      },
      "users-login": {
        "ClusterId": "users",
        "AuthorizationPolicy": "anonymous",
        "Match": {
          "Path": "/api/users/login",
          "Methods": [ "POST" ]
        }
      },
      "users": {
        "ClusterId": "users",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/users/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "finance": {
        "Destinations": {
          "finance-destination": {
            "Address": "http://localhost:5002/"
          }
        }
      },
      "users": {
        "Destinations": {
          "users-destination": {
            "Address": "http://localhost:5001/"
          }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*"
}
